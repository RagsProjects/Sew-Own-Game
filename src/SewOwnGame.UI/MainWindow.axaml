<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SewOwnGame.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="SewOwnGame.UI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Sew Own Game"
        Width="1000" Height="600"
        MinWidth="600" MinHeight="400">

    <Window.Styles>

        <Style Selector="Button.sidebar-btn">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.sidebar-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SidebarHoverBg}"/>
        </Style>
        <Style Selector="Button.sidebar-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SidebarHoverBg}"/>
        </Style>

        <Style Selector="Button.sidebar-btn.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SidebarHoverBg}"/>
        </Style>

        <Style Selector="Button.settings-action-btn">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style Selector="Button.theme-toggle-btn">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CloseButtonBorder}"/>
            <Setter Property="Background" Value="{DynamicResource CloseButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CloseButtonForeground}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style Selector="Button.theme-toggle-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark3}"/>
        </Style>

        <Style Selector="Button.overlay-close">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.overlay-close /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.overlay-close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.overlay-close:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

    </Window.Styles>

    <Grid>

        <!-- ════════════════════════════════════════════
             MAIN LAYOUT: Sidebar + Content
             ════════════════════════════════════════════ -->
        <Grid ColumnDefinitions="48,*">

            <!-- ─── SIDEBAR ─── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarActiveBg}"
                    BorderBrush="{DynamicResource SystemAccentColorDark3}"
                    BorderThickness="0,0,1,0">

                <DockPanel LastChildFill="False">

                    <StackPanel DockPanel.Dock="Top"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,18">
                        <Border Width="40" Height="40"
                                CornerRadius="8"
                                Background="{DynamicResource SidebarActiveIcon}"
                                ToolTip.Tip="Sew Own Game">
                            <TextBlock Text="🧵"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <Border DockPanel.Dock="Top"
                            Height="1"
                            Background="{DynamicResource SidebarActiveBg}"
                            Margin="8,0"/>

                    <StackPanel DockPanel.Dock="Top"
                                Margin="8,8,8,0"
                                Spacing="4">
                        <Button Classes="sidebar-btn active"
                                ToolTip.Tip="Projects">
                            <TextBlock Text="📁"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom"
                                Margin="8,8,8,8"
                                Spacing="4">
                        <Button Classes="sidebar-btn"
                                Name="SettingsButton"
                                ToolTip.Tip="Settings"
                                Click="OnSettingsClick">
                            <TextBlock Name="SettingsIcon"
                                       Text="⚙"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SidebarSettingsIcon}"/>
                        </Button>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- ─── MAIN CONTENT ─── -->
            <Grid Grid.Column="1" Margin="28,24,28,24">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                        <TextBlock Text="Projects"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="All game projects detected on system"
                                   FontSize="13"
                                   Foreground="Gray"/>
                        <Button Content="Scan Projects"
                                Command="{Binding ScanProjectsCommand}"
                                IsEnabled="{Binding !IsLoading}"
                                Margin="0,10,0,0"
                                Padding="16,8"/>
                        <Button Content="Select Project Folder"
                                Command="{Binding ImportProjectCommand}"
                                IsEnabled="{Binding !IsLoading}"
                                Margin="0,8,0,0"
                                Padding="16,8"/>
                    </StackPanel>

                    <!-- Permission warning -->
                    <Border Grid.Row="1"
                            IsVisible="{Binding HasPermissionErrors}"
                            Background="#FFF3CD"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="⚠️ Permission Warning"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#856404"/>
                            <TextBlock Text="{Binding PermissionWarningMessage}"
                                       FontSize="12"
                                       Foreground="#856404"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Projects List -->
                    <Border Grid.Row="2"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid>

                            <!-- Loading -->
                            <TextBlock Text="Scanning Projects..."
                                       IsVisible="{Binding IsLoading}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Foreground="Gray"/>

                            <!-- Empty state -->
                            <StackPanel IsVisible="{Binding IsEmpty}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <TextBlock Text="🎮"
                                           FontSize="40"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No project found! Click 'import project' to manually find it"
                                           FontSize="15"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Click in 'Search Projects' to start!"
                                           FontSize="12"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Project items -->
                            <ScrollViewer IsVisible="{Binding HasProjects}">
                                <ItemsControl ItemsSource="{Binding Projects}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="LightGray"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="10"
                                                    Margin="0,0,0,4">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Path}"
                                                               FontSize="11"
                                                               Foreground="Gray"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                                        <TextBlock Text="{Binding EngineType, StringFormat='Engine: {0}'}"
                                                                   FontSize="11"/>
                                                        <TextBlock Text="{Binding EngineVersion, StringFormat='Version: {0}'}"
                                                                   FontSize="11"/>
                                                        <TextBlock Text="{Binding DisplaySize}"
                                                                   FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                        </Grid>
                    </Border>

                </Grid>
            </Grid>

        </Grid>
        <!-- END MAIN LAYOUT -->


        <!-- ════════════════════════════════════════════
             OVERLAY: dim backdrop + settings panel
             ════════════════════════════════════════════ -->
        <Grid Name="SettingsOverlay"
              IsVisible="False">

            <Border Background="#000000"
                    Opacity="0.55"
                    Name="OverlayBackdrop"/>
            <Button Classes="overlay-close"
                    Click="OnOverlayBackdropClick"/>

            <Border Name="SettingsPanel"
                    Width="320"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Margin="64,0,0,0"
                    Background="{DynamicResource SystemAccentColorDark1}"
                    BorderBrush="{DynamicResource SystemAccentColorLight3}"
                    BorderThickness="0,0,1,0"
                    BoxShadow="4 0 24 0 #40000000">

                <Grid RowDefinitions="Auto,*,Auto" Margin="20,24,20,20">

                    <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,20">
                        <TextBlock Text="Settings"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#E8E8F5"/>
                        <Border Height="1"
                                Background="#aaaaaa"
                                Margin="0,10,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="24">

                        <StackPanel Spacing="10">
                            <TextBlock Text="Interface Theme"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#aaaaaa"
                                       LetterSpacing="1"/>

                            <Button Name="ThemeToggleButton"
                                    Classes="theme-toggle-btn"
                                    Click="OnThemeToggleClick">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Name="ThemeIcon"
                                               Text="☀️"
                                               FontSize="18"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Name="ThemeLabel"
                                                   Text="Light Theme"
                                                   FontSize="13"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource CloseButtonText}"/>
                                        <TextBlock Name="ThemeSubLabel"
                                                   Text="Click me for Light Theme!"
                                                   FontSize="10"
                                                   Foreground="#aaaaaa"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </StackPanel>

                    <Button Grid.Row="2"
                            Classes="close-btn"
                            Content="Close"
                            HorizontalAlignment="Right"
                            Padding="16,8"
                            CornerRadius="8"
                            Click="OnSettingsClick"/>

                </Grid>
            </Border>

        </Grid>
        <!-- END OVERLAY -->

        <!-- ════════════════════════════════════════════
                FLOATING ERROR: Invalid folder
            ════════════════════════════════════════════ -->
            <Border IsVisible="{Binding ShowInvalidFolderError}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,24"
                    Padding="16,12"
                    CornerRadius="10"
                    Background="{DynamicResource SystemAccentColorDark1}"
                    BorderBrush="{DynamicResource SystemAccentColorLight3}"
                    BorderThickness="1"
                    BoxShadow="0 4 24 0 #60000000"
                    MaxWidth="480">
                <Grid ColumnDefinitions="*,Auto">

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{Binding FloatingErrorMessage}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#EEEEEE"
                                TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="If you think this is a mistake,"
                                    FontSize="12"
                                    Foreground="#CCCCCC"/>
                            <Button Content="send us an Issue on GitHub"
                                    Command="{Binding OpenGitHubIssuesCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Foreground="{DynamicResource LinkColor}"
                                    FontSize="12"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="✕"
                            Command="{Binding DismissInvalidFolderErrorCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#aaaaaa"
                            FontSize="12"
                            Padding="4,0,4,0"
                            VerticalAlignment="Top"
                            Cursor="Hand"/>
                </Grid>
            </Border>

    </Grid>
</Window>